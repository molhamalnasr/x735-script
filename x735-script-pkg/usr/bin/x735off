#!/usr/bin/env bash

set -e

SLEEP=${1:-4}

readonly BUTTON=20
readonly GPIO_CHIP=0

readonly PERMISSION_DENIED="151"
readonly INVALID_CLI_ARG_TYPE="153"

# Source the GPIO helper script
readonly HELPER_PATH="/usr/lib/x735-script/scripts/gpio-helper.sh"
if [ -f "$HELPER_PATH" ]; then
    source "$HELPER_PATH"
else
    # Fallback if running from source folder during development/testing
    source "$(dirname "${BASH_SOURCE[0]}")/../lib/x735-script/scripts/gpio-helper.sh"
fi

terminate() {
    local -r msg=$1
    local -r err_code=${2:-150}
    echo "${msg}" >&2
    exit "${err_code}"
}

# Guard clause to check if the script is running with root privileges (sudo)
if [[ $EUID -ne 0 ]]; then
    terminate "This script must be run with root privileges (sudo)." "${PERMISSION_DENIED}"
fi

if ! [[ $SLEEP =~ ^[0-9\.]+$ ]] ; then
   terminate "error: sleep time not a number" "${INVALID_CLI_ARG_TYPE}"
fi

gpio_cleanup() {
   gpio_cleanup_pin "$BUTTON"
   terminate "unexpected error..."
}

# Main method
__main__() {
  gpio_init_output "$GPIO_CHIP" "$BUTTON" 1
  
  # Handle exit and interrupt signals to cleanup GPIO
  trap gpio_cleanup EXIT SIGINT SIGTERM

  # Broadcast the shutdown message to all tty sessions.
  printf "Your device will shut down in %d seconds...\n" "$SLEEP" | wall
  sleep "$SLEEP"

  gpio_set_value "$GPIO_CHIP" "$BUTTON" 0
  gpio_cleanup_pin "$BUTTON"
}

__main__